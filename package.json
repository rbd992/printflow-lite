{
  "name": "printflow-lite",
  "version": "0.1.4-beta",
  "description": "PrintFlow Lite â€” Standalone 3D Print Business Suite",
  "main": "src/main/main.js",
  "author": {
    "name": "Robert Dunn",
    "email": "rob@printflow.app"
  },
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "cross-env REACT_APP_LITE=true react-scripts start",
    "react-build": "cross-env REACT_APP_LITE=true react-scripts build",
    "electron-dev": "ELECTRON_START_URL=http://localhost:3000 REACT_APP_LITE=true electron .",
    "build": "npm run react-build && electron-builder",
    "build:mac": "npm run react-build && electron-builder --mac",
    "build:win": "npm run react-build && electron-builder --win",
    "build:linux": "npm run react-build && electron-builder --linux AppImage",
    "install-server": "cd src/server && npm install"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cross-env": "^7.0.3",
    "date-fns": "^3.3.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.2",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.printflow.lite",
    "productName": "PrintFlow Lite",
    "copyright": "Copyright Â© 2026 PrintFlow",
    "extends": null,
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/server",
        "to": "server",
        "filter": ["**/*", "!*.log"]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "dmg", "arch": ["x64"] }
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "sign": false,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "publisherName": "PrintFlow",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PrintFlow Lite",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "Office",
      "artifactName": "PrintFlowLite-${version}.AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "rbd992",
      "repo": "printflow-lite",
      "releaseType": "release"
    }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version"]
  }
}
